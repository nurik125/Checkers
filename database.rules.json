{
  "rules": {
    "players": {
      "$uid": {
        ".read": "auth.uid === $uid",
        ".write": "auth.uid === $uid"
      }
    },
    "games": {
      "$gameId": {
        ".read": "auth.uid !== null",
        ".write": "auth.uid !== null && (
          root.child('games').child($gameId).child('players/white/id').val() === auth.uid ||
          root.child('games').child($gameId).child('players/black/id').val() === auth.uid
        )",
        "players": {
          "black": {
            ".write": "auth.uid !== null && (
              root.child('games').child($gameId).child('players/black/id').val() === null &&
              newData.child('id').val() === auth.uid
            )"
          }
        }
      }
    }
  }
}